{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(/home/user/internal-tools/**)",
      "Edit(/home/user/internal-tools/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/user/internal-tools/.claude/hooks/scope-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/user/internal-tools/.claude/hooks/scope-guard.sh"
          }
        ]
      },
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "/home/user/internal-tools/.claude/hooks/web-safety.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/user/internal-tools/.claude/hooks/memory-update.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/home/user/internal-tools/.claude/hooks/plan-checkpoint.sh"
          }
        ]
      }
    ]
  }
}
