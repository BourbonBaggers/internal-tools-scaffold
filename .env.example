# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=internal_tools

# ─── API ─────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
CORS_ORIGIN=http://localhost:8080

# ─── Deploy script (set locally — never commit actual values) ─────────────────
# PROD_SSH_HOST=prod-server-hostname
# PROD_SSH_USER=deploy
# PROD_APP_DIR=/opt/internal-tools
# PROD_HEALTH_URL=http://localhost:8080/health

# ─── Backup script (set on prod server — never commit) ───────────────────────
# BACKUP_DEST_USER=yourusername
# BACKUP_DEST_HOST=mac-mini.local
# BACKUP_DEST_PATH=/Users/yourusername/Documents/utility-backup/internal-tools
