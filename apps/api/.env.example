# ─── Database ────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:devpassword@localhost:5432/internal_tools_dev

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Notifications (ntfy) ────────────────────────────────────────────────────
# Leave blank to disable notifications
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=your-private-topic-name
